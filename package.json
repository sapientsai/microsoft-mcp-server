{
  "name": "microsoft-mcp-server",
  "version": "0.1.0",
  "description": "Microsoft Graph MCP Server - Access Microsoft Graph API through the Model Context Protocol",
  "keywords": [
    "mcp",
    "microsoft-graph",
    "azure",
    "oauth",
    "typescript"
  ],
  "author": "jordan.burke@gmail.com",
